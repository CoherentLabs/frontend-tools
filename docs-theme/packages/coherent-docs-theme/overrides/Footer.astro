---
import type { Props } from '@astrojs/starlight/props';
import DefaultFooter from '@astrojs/starlight/components/Footer.astro';

const currentYear = new Date().getFullYear();
---

<DefaultFooter {...Astro.props} />

<div class="custom-copyright">
    <p>
        &copy; {currentYear} <strong>Coherent Labs</strong>. All rights reserved.
    </p>
    <div class="links">
        <a href="https://coherent-labs.com/privacy-policy" target="_blank">Privacy Policy</a>
    </div>
</div>

<style>
    .custom-copyright {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--sl-color-hairline);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        text-align: center;
        color: var(--sl-color-gray-3);
        font-size: 0.85rem;
    }

    .custom-copyright strong {
        color: var(--sl-color-white);
    }

    .links {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }

    .links a {
        color: var(--sl-color-gray-3);
        text-decoration: none;
        transition: color 0.2s;
    }

    .links a:hover {
        color: var(--sl-color-accent);
    }
</style>