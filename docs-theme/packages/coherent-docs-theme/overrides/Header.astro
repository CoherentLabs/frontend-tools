---
import config from "virtual:starlight/user-config";
import LanguageSelect from "@astrojs/starlight/components/LanguageSelect.astro";
import SiteTitle from "@astrojs/starlight/components/SiteTitle.astro";
import SocialIcons from "@astrojs/starlight/components/SocialIcons.astro";
import ThemeSelect from "./ThemeSelect.astro";
import ProgressIndicator from "../internal-components/ProgressIndicator.astro";
import getThemeConfig from "../internal/themeConfig";
import NavLinks from "../internal-components/NavLinks.astro";
import Search from "./Search.astro";

const { showPageProgress } = getThemeConfig();
const shouldRenderSearch =
    config.pagefind ||
    config.components.Search !== "@astrojs/starlight/components/Search.astro";
---

{showPageProgress && <ProgressIndicator />}
<div class="header sl-flex">
    <div class="left-group">
        <div class="site-title-wrapper">
            <SiteTitle />
        </div>

        <div class="nav-wrapper">
            <NavLinks />
        </div>
    </div>

    <div class="right-group print:hidden">
        <div class="search-container">
            {shouldRenderSearch && <Search />}
        </div>
        <div class="actions-wrapper sl-hidden md:sl-flex">
            <SocialIcons />
            <ThemeSelect />
            <LanguageSelect />
        </div>
    </div>
</div>

<style>
    .header {
        gap: var(--sl-nav-gap);
        justify-content: space-between;
        align-items: center;
        height: 100%;
        width: 100%;
        display: flex;
    }

    .left-group {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex: 1 1 auto;
        min-width: 0;
    }

    .site-title-wrapper {
        flex-shrink: 0;
    }

    .nav-wrapper {
        flex: 1;
        min-width: 0;
        display: flex;
        justify-content: flex-start;
        overflow: visible;
        align-items: center;
    }

    .right-group {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex: 0 0 auto;
        margin-left: auto;
        min-width: 0;
    }

    .search-container {
        flex: 0 1 auto;
        min-width: 0;
    }
    .search-container :global(site-search),
    .search-container :global(site-search > button) {
        min-width: 24rem;
    }

    @media (max-width: 50rem) {
        .search-container :global(site-search),
        .search-container :global(site-search > button) {
            min-width: 0rem;
        }
    }

    @media (min-width: 50rem) {
        .header.nav-collapsed .left-group {
            flex: 0 0 auto;
        }

        .header.nav-collapsed .nav-wrapper {
            flex: 0 0 auto;
        }

        .header.nav-collapsed .right-group {
            flex: 1 1 auto;
        }

        .header.nav-collapsed .search-container {
            flex: 1 1 auto;
            max-width: none;
        }

        .header.nav-collapsed .search-container :global(site-search),
        .header.nav-collapsed .search-container :global(site-search > button) {
            width: 100%;
            min-width: 0;
            max-width: none;
        }
    }

    .actions-wrapper {
        flex-shrink: 0;
        align-items: center;
        gap: 1rem;
    }

    .vertical-separator {
        width: 1px;
        height: 1.5rem;
        background-color: var(--sl-color-gray-5);
    }
</style>
