---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { imageRegistry } from "../utils/imageRegistry";

interface Props {
    src: string | ImageMetadata;
    alt?: string;
    caption?: string;
    title?: string;
    class?: string;
    link?: string;
    target?: string;
    rel?: string;
    width?: number | string;
    height?: number | string;
    attr?: string;
    attrlink?: string;
}

const {
    src,
    alt,
    caption,
    title,
    class: className,
    link,
    target,
    rel,
    width,
    height,
    attr,
    attrlink,
} = Astro.props;

const altText = alt || caption || "";

let isLocal = typeof src === "object";
let resolvedImage: ImageMetadata | string = src as any;

if (typeof src === "string") {
    if (src.startsWith("/") && !src.startsWith("//")) {
        isLocal = false;
    } else if (!src.startsWith("http") && !src.startsWith("data:")) {
        const fileName = src.replace(/^\.\//, '').split('/').pop() || src;
        
        const importFn = imageRegistry.get(fileName);
        
        if (importFn) {
            resolvedImage = (await importFn()).default;
            isLocal = true;
        } else {
            console.warn(`[Figure] Image not found in registry: ${src}`);
            isLocal = false;
        }
    }
}
---

<figure class={className}>
    {
        link ? (
            <a href={link} target={target} rel={rel}>
                {isLocal ? (
                    <Image
                        src={resolvedImage as ImageMetadata}
                        alt={altText}
                        title={title}
                        width={width as any}
                        height={height as any}
                    />
                ) : (
                    <img
                        src={resolvedImage as string}
                        alt={altText}
                        title={title}
                        width={width}
                        height={height}
                    />
                )}
            </a>
        ) : isLocal ? (
            <Image
                src={resolvedImage as ImageMetadata}
                alt={altText}
                title={title}
                width={width as any}
                height={height as any}
            />
        ) : (
            <img
                src={resolvedImage as string}
                alt={altText}
                title={title}
                width={width}
                height={height}
            />
        )
    }

    {
        (caption || attr) && (
            <figcaption>
                {caption && <p>{caption}</p>}

                {attr && (
                    <p>{attrlink ? <a href={attrlink}>{attr}</a> : attr}</p>
                )}
            </figcaption>
        )
    }
</figure>

<style>
    figure {
        margin: 2rem 0;
        text-align: center;
    }
    figcaption {
        margin-top: 0.5rem;
        font-size: 0.9rem;
        color: var(--sl-color-gray-3);
        text-align: start;
    }
    figcaption p {
        margin: 0;
    }
</style>