---
interface Props {
    sticky?: boolean;
}

const { sticky = false } = Astro.props;
---

<div class={sticky ? "custom-sticky-table" : "custom-standard-table"}>
    <slot />
</div>

<style is:global>
    .custom-sticky-table table th, 
    .custom-sticky-table table thead {
        position: sticky;
        top: 0;
        z-index: 10;
        background-color: var(--sl-color-bg);
        box-shadow: 0 2px 0 var(--sl-color-hairline);
    }
</style>
