---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
    src1: string | ImageMetadata;
    src2: string | ImageMetadata;
    alt1?: string;
    alt2?: string;
}

const { src1, src2, alt1 = "Before image", alt2 = "After image" } = Astro.props;

const isLocal1 = typeof src1 === "object";
const isLocal2 = typeof src2 === "object";
---

<figure class="center">
    <div class="image-slider">
        <div class="slider-overlay">
            {
                isLocal1 ? (
                    <Image src={src1 as ImageMetadata} alt={alt1} />
                ) : (
                    <img src={src1 as string} alt={alt1} />
                )
            }
        </div>

        {
            isLocal2 ? (
                <Image src={src2 as ImageMetadata} alt={alt2} />
            ) : (
                <img src={src2 as string} alt={alt2} />
            )
        }
    </div>
</figure>

<style>
    .center {
        text-align: center;
        margin: 2rem 0;
    }

    .image-slider {
        position: relative;
        display: inline-block;
        line-height: 0;
    }

    .image-slider img {
        user-select: none;
        max-width: 70vw;
        display: block;
        height: auto;
        margin: 0 !important;
        padding: 0 !important;
    }

    .slider-overlay {
        position: absolute;
        top: 0;
        bottom: 0;
        left: 0;
        width: 2%;
        max-width: 100%;
        overflow: hidden;
        resize: horizontal;
        border-right: 3px var(--before-after-line) solid;
        box-sizing: border-box;
        animation: slidejitter 2s ease-in-out 0.1s 1;
    }

    .slider-overlay:before {
        position: absolute;
        bottom: 3px;
        right: 3px;
        content: "";
        display: block;
        height: 3vw;
        width: 3vw;
        box-shadow: 3px 6px 2px 0 black;
        overflow: hidden;
        resize: horizontal;
        background-clip: content-box;
        background: linear-gradient(-45deg, white 50%, transparent 0);
    }

    @keyframes slidejitter {
        25% {
            width: 2%;
        }
        75% {
            width: 5%;
        }
        100% {
            width: 2%;
        }
    }

    @media (min-width: 600px) {
        .image-slider img {
            max-width: 50vw;
        }
        .slider-overlay:before {
            width: 2vw;
            height: 2vw;
        }
    }

    @media (min-width: 1200px) {
        .image-slider img {
            max-width: 40vw;
        }
        .slider-overlay {
            width: 10%;
        }
        .slider-overlay:before {
            width: 1vw;
            height: 1vw;
        }
    }
</style>
