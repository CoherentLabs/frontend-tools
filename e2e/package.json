{
  "name": "gameface-e2e",
  "version": "2.2.0",
  "scripts": {
    "build": "tsc && vite build",
    "run-test": "node ./scripts/test.js --port=54321",
    "dev:host": "http-server ./examples -p 54321",
    "test": "npm run build&&start-server-and-test dev:host http://localhost:54321/ run-test",
    "publish:package": "npm i&&npm run build&&npm publish"
  },
  "dependencies": {
    "@oclif/core": "^4.2.8",
    "assert": "^2.1.0",
    "axios": "^1.8.1",
    "detect-port": "^2.1.0",
    "glob": "^11.0.1",
    "http-server": "^14.1.1",
    "mocha": "^11.1.0",
    "oclif": "^4.17.34",
    "start-server-and-test": "^2.0.12",
    "tree-kill": "^1.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "ws": "^8.18.1"
  },
  "types": "./types/global.d.ts",
  "bin": {
    "gameface-e2e": "./bin/run.js"
  },
  "oclif": {
    "bin": "gameface-e2e",
    "commands": {
      "strategy": "single",
      "target": "./dist/index.js"
    },
    "dirname": "./",
    "topicSeparator": " "
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/ws": "^8.18.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
