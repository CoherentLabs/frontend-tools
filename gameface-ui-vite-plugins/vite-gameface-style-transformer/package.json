{
    "name": "vite-plugin-gameface-styles",
    "version": "2.0.0",
    "type": "module",
    "description": "A framework agnostic Vite plugin that converts inline styles to UnoCSS classes for better performance and maintainability.",
    "main": "dist/index.js",
    "scripts": {
        "build": "npm run clean:dist&&rollup -c",
        "dev": "rollup -c -w",
        "publish:package": "npm run clean&&npm i&&rollup -c&&npm publish",
        "clean:dist": "rm -rf dist",
        "clean": "npm run clean:dist&&rm -rf node_modules&&rm package-lock.json"
    },
    "types": "dist/index.d.ts",
    "author": "CoherentLabs",
    "license": "ISC",
    "devDependencies": {
        "@babel/generator": "^7.27.0",
        "@babel/parser": "^7.27.0",
        "@babel/traverse": "^7.27.0",
        "@babel/types": "^7.27.0",
        "@rollup/plugin-commonjs": "^28.0.3",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.1",
        "@rollup/plugin-typescript": "^12.1.2",
        "@types/babel__generator": "^7.6.8",
        "@types/babel__traverse": "^7.20.7",
        "@types/node": "^22.13.14",
        "rollup": "^4.38.0",
        "tslib": "^2.8.1",
        "typescript": "^5.8.2",
        "vite": "^5.4.10",
        "preact": "^10.29.0",
        "react": "^19.2.4",
        "rollup-plugin-copy": "^3.5.0",
        "solid-js": "^1.9.11",
        "@vue/runtime-dom": "^3.5.30",
        "unocss": "^0.65.4"
    },
    "peerDependencies": {
        "unocss": ">=0.60.0"
    },
    "dependencies": {
        "magic-string": "^0.30.21"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./solid": {
            "types": "./dist/types/solid.d.ts"
        },
        "./react": {
            "types": "./dist/types/react.d.ts"
        },
        "./preact": {
            "types": "./dist/types/preact.d.ts"
        },
        "./vue": {
            "types": "./dist/types/vue.d.ts"
        },
        "./svelte": {
            "types": "./dist/types/svelte.d.ts"
        }
    }
}
