{
  "name": "vite-gameface",
  "version": "1.0.2",
  "type": "module",
  "description": "A Vite plugin for integrating Gameface UI into your Gameface projects.",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run clean:dist&&rollup -c",
    "dev": "rollup -c -w",
    "publish:package": "npm run clean&&npm i&&rollup -c&&npm publish",
    "clean:dist": "rm -rf dist",
    "clean": "npm run clean:dist&&rm -rf node_modules&&rm package-lock.json"
  },
  "types": "dist/index.d.ts",
  "author": "CoherentLabs",
  "license": "ISC",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^22.13.14",
    "dom-serializer": "^2.0.0",
    "htmlparser2": "^10.0.0",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2",
    "vite": "^5.4.10"
  }
}
